<div class="super-button-wrapper">
    <div class="super-menu" id="superMenu">
        <div class="menu-header">Roxy+ Hub</div>

        <a href="/" class="menu-item <%= page === 'home' ? 'active' : '' %>">
            <span class="icon">🏠</span>
            <span class="label">Dashboard</span>
        </a>

        <a href="/afk" class="menu-item <%= page === 'afk' ? 'active' : '' %>">
            <span class="icon">💤</span>
            <span class="label">AFK System</span>
        </a>

        <a href="/commands" class="menu-item <%= page === 'commands' ? 'active' : '' %>">
            <span class="icon">⚡</span>
            <span class="label">Commands</span>
        </a>

        <a href="/ai" class="menu-item <%= page === 'ai' ? 'active' : '' %>">
            <span class="icon">🧠</span>
            <span class="label">AI Chat</span>
        </a>

        <a href="/music" class="menu-item <%= page === 'music' ? 'active' : '' %>">
            <span class="icon">🎵</span>
            <span class="label">Music</span>
        </a>

        <a href="/quest" class="menu-item <%= page === 'quest' ? 'active' : '' %>">
            <span class="icon">⚔️</span>
            <span class="label">Quests</span>
        </a>

        <a href="/server-cloner" class="menu-item <%= typeof page !== 'undefined' && page === 'cloner' ? 'active' : '' %>">
            <span class="icon">🔄</span>
            <span class="label">Cloner</span>
        </a>

        <div style="height: 1px; background: rgba(255,255,255,0.1); margin: 10px 0;"></div>
        <div class="menu-header" style="margin-top: 5px;">Accounts</div>
        <% if (typeof clients !== 'undefined' && clients.length > 0) { %>
            <% clients.forEach(function(c) { %>
                <a href="#" class="menu-item <%= typeof activeClientKey !== 'undefined' && activeClientKey === c.tokenKey ? 'active' : '' %>" onclick="switchClient('<%= c.tokenKey %>')">
                    <span class="icon">👤</span>
                    <span class="label"><%= c.user ? c.user.username : c.tokenKey %></span>
                </a>
            <% }) %>
        <% } %>
    </div>

    <button class="super-btn" id="superBtn" onclick="toggleSuperMenu()"
        style="background: transparent !important; box-shadow: none !important; padding: 0; -webkit-tap-highlight-color: transparent; outline: none;">
        <img src="/super.png" alt="Super" style="width: 100%; height: 100%; object-fit: contain; border-radius: 50%;">
    </button>
</div>

<div class="super-overlay" id="superOverlay" onclick="toggleSuperMenu()"></div>

<script>
    function toggleSuperMenu() {
        const menu = document.getElementById('superMenu');
        const btn = document.getElementById('superBtn');
        const overlay = document.getElementById('superOverlay');

        menu.classList.toggle('open');
        btn.classList.toggle('active');
        overlay.classList.toggle('visible');
    }

    function switchClient(key) {
        fetch('/api/switch_client', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key })
        }).then(res => res.json()).then(data => {
            if (data.success) {
                window.location.reload();
            }
        });
    }
</script>